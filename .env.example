# Copy to `.env` and adjust values.
# postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev@localhost:5432/atlas_dev
# Optional: omit or leave empty to reuse DATABASE_URL (single DB for dev + tests).
TEST_DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev@localhost:5432/atlas_test

# Default LLM: groq (OpenAI-compatible) | gemini | claude | openai
LLM_PROVIDER=groq

# Groq (https://console.groq.com) — OpenAI-compatible API
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=qwen/qwen3-32b

# Gemini (optional; used when LLM_PROVIDER=gemini, or later for embeddings-only flows)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_MAX_CONTEXT_TOKENS=1048576

# Pytest defaults ATLAS_USE_FAKE_LLM=1 in tests/conftest.py (no external LLM calls). Unset for live API tests.

# local | prod — controls log rendering (JSON in prod)
ENV=local

LOG_LEVEL=INFO

# IANA timezone for scheduled jobs and prompts (Phase 8+)
TIMEZONE=Asia/Karachi

# Superuser connection for `make reset-db` only (postgres user recommended).
# Example: postgresql+asyncpg://postgres:YOUR_SUPERUSER_PASSWORD@localhost:5432/postgres
ATLAS_ADMIN_DATABASE_URL=
